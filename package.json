{
  "name": "github-pr-comments-retriever",
  "displayName": "GitHub PR Comments Retriever",
  "description": "Retrieve and save all comments from a GitHub pull request",
  "version": "0.1.3",
  "packageManager": "pnpm@9.0.0",
  "icon": "assets/github-pr-logo.png",
  "publisher": "vernonthedev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vernonthedev/pr-comments-retriever.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "pnpm": {
    "overrides": {
      "eslint": "$eslint"
    },
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "keytar"
    ]
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:github-pr-comments-retriever.retrievePR"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "github-pr-comments-retriever.retrievePR",
        "title": "Retrieve PR Comments"
      }
    ],
    "keybindings": [
      {
        "command": "github-pr-comments-retriever.retrievePR",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "github-pr-comments-retriever.retrievePR",
          "when": "true",
          "title": "Retrieve PR Comments"
        }
      ]
    },
    "configuration": {
      "title": "GitHub PR Comments Retriever",
      "properties": {
        "github-pr-comments-retriever.token": {
          "type": "string",
          "description": "GitHub Personal Access Token for API authentication"
        },
        "github-pr-comments-retriever.saveLocation": {
          "type": "string",
          "enum": [
            "workspace",
            "home"
          ],
          "default": "workspace",
          "description": "Where to save PR data: 'workspace' uses the current folder, 'home' uses your home directory"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
